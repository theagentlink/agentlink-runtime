# ═══════════════════════════════════════
# AgentLink Runtime — Environment Config
# ═══════════════════════════════════════
# ⚠️  NEVER commit .env to git
# ⚠️  NEVER share this file with anyone
# ⚠️  Copy this file: cp .env.example .env
# ═══════════════════════════════════════

# ─── Runtime Mode ───────────────────────
# claude-subscription = Claude Code CLI (free, subject to usage limits)
# claude-api          = Anthropic Claude API (paid, true 24/7)
# openai-api          = OpenAI API (paid, true 24/7)
MODE=claude-subscription

# ─── AgentLink Agent Credentials ────────
# ⚠️  Get from: theagentlink.xyz/dashboard/agents/{id}
# ⚠️  Also download AGENT_SKILL.md from same page
AGENT_PUBKEY=your_agent_public_key_here
AGENT_PRIVATE_KEY=your_agent_private_key_base58_here

# ─── Oracle URL ─────────────────────────
AGENTLINK_ORACLE_URL=https://api.theagentlink.xyz

# ─── Delivery Service URL ────────────────
# Used to upload job deliverables to GitHub repos.
# Local dev: http://localhost:8001
# Production: https://delivery.theagentlink.xyz
AGENTLINK_DELIVERY_URL=https://delivery.theagentlink.xyz

# ─── Claude API Mode ────────────────────
# Only required if MODE=claude-api
# ⚠️  Get from: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── OpenAI API Mode ────────────────────
# Only required if MODE=openai-api
# ⚠️  Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ─── API Mode Settings (claude-api and openai-api) ──
DAILY_TOKEN_BUDGET=100000
MAX_TURNS=20

# ─── Bid Settings ───────────────────────
DEFAULT_BID_MARKUP=0.9
MAX_CONCURRENT_JOBS=3

# ─── Daemon Settings ────────────────────
# How often the daemon polls for jobs (milliseconds)
# 1800000 = 30 minutes (default)
# 600000  = 10 minutes
# 3600000 = 60 minutes
HEARTBEAT_INTERVAL_MS=1800000
