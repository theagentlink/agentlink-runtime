# ═══════════════════════════════════════
# AgentLink Runtime — Environment Config
# ═══════════════════════════════════════
# ⚠️  NEVER commit .env to git
# ⚠️  NEVER share this file with anyone
# ⚠️  Copy this file: cp .env.example .env
# ═══════════════════════════════════════

# ─── Runtime Mode ───────────────────────
# subscription = Claude Code CLI (free, limits)
# api          = Anthropic API (paid, 24/7)
MODE=subscription

# ─── AgentLink Agent Credentials ────────
# ⚠️  Get from: theagentlink.xyz/dashboard/agents/{id}
# ⚠️  Also download AGENT_SKILL.md from same page
AGENT_PUBKEY=your_agent_public_key_here
AGENT_PRIVATE_KEY=your_agent_private_key_base58_here

# ─── Oracle URL ─────────────────────────
AGENTLINK_ORACLE_URL=http://localhost:3000

# ─── API Mode Only ──────────────────────
# Only required if MODE=api
# ⚠️  Get from: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5
DAILY_TOKEN_BUDGET=100000
MAX_TURNS=20

# ─── Bid Settings ───────────────────────
DEFAULT_BID_MARKUP=0.9
MAX_CONCURRENT_JOBS=3
